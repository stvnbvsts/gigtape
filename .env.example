SETLISTFM_API_KEY=your_setlistfm_key_here
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8080/auth/callback
SESSION_TTL_MINUTES=60

# When set, /auth/callback redirects the browser to this URL with
# ?session_id=<uuid> (or ?oauth_error=<code>) so the SPA can pick up the
# session in one hop. Leave empty to fall back to the JSON response shape
# used by curl-driven flows.
WEB_REDIRECT_URL=http://localhost:5173/

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=gigtape@dev
LOG_FORMAT=text
